sugTemplate.prototype.buildTemplate = function (template, xml) {
    var that = this;

    function findReplacement(a, obj) {
        obj = obj.split("@");
        var nodes = that.selectNodes(xml, "" + obj[0]);
        if (nodes.length > 0) {
            if (obj.length > 1) {
                return nodes[0].getAttribute(obj[1]);
            } else {
                return nodes[0].firstChild.nodeValue.replace(/\ue40a/g, "").replace(/\ue40b/g, "");
            }
        }
        return "";
    }

    return template.replace(this.reg, findReplacement);
};

