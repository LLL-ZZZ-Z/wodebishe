    // 提交计数器功能
    function getCookie() {
        var dc = d.cookie;
        var prefix = "sct=";
        var begin = dc.indexOf("; " + prefix);
        if (begin == -1) {
            begin = dc.indexOf(prefix);
            if (begin != 0) {
                return null;
            }
        } else {
            begin += 2;
        }
        var end = dc.indexOf(";", begin);
        if (end == -1) {
            end = dc.length;
        }
        return dc.substring(begin + prefix.length, end);
    }

    function increaseSct() {
