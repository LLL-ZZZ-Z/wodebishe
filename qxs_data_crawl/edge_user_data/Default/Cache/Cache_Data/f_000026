            return;  // not left click
        }
        evt = evt || window.event;
        var srcElem = ((evt.target) ? evt.target : evt.srcElement), h;
        while (srcElem && srcElem.tagName) {
            if (srcElem.tagName.toUpperCase() == "A") {
                h = srcElem.href || "";
                if ((h.indexOf("http://www.sogou.com/") == 0 || h.indexOf("https://www.sogou.com/") == 0) && h.indexOf("query=") > 0) {
                    increaseSct()
                }
                return
            }
            srcElem = srcElem.parentNode
        }
